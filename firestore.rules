rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && currentUserDoc().data.role == "admin";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.id == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.role == "user"
        && request.resource.data.balance == 0
        && request.resource.data.linkedBank == null;

      allow update: if isAdmin()
        || (
          isOwner(userId)
          && resource.data.role == request.resource.data.role
          && resource.data.balance == request.resource.data.balance
          && resource.data.username == request.resource.data.username
          && resource.data.createdAt == request.resource.data.createdAt
          && (
            resource.data.linkedBank == null
            || resource.data.linkedBank == request.resource.data.linkedBank
          )
        );
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.status == "processing"
        && request.resource.data.reviewedAt == null
        && request.resource.data.productId == ""
        && request.resource.data.productName == ""
        && request.resource.data.affiliateLink == ""
        && request.resource.data.commissionValue == 0;

      allow update: if isAdmin()
        && resource.data.status == "processing"
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.username == resource.data.username
        && request.resource.data.orderCode == resource.data.orderCode
        && request.resource.data.submittedAt == resource.data.submittedAt
        && (
          request.resource.data.status == "completed"
          || request.resource.data.status == "rejected"
        );
      allow delete: if false;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.status == "pending";

      allow update: if isAdmin()
        && resource.data.status == "pending"
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.username == resource.data.username
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.bankName == resource.data.bankName
        && request.resource.data.accountNumber == resource.data.accountNumber
        && request.resource.data.accountHolder == resource.data.accountHolder
        && request.resource.data.requestedAt == resource.data.requestedAt
        && (
          request.resource.data.status == "paid"
          || request.resource.data.status == "cancelled"
        );
      allow delete: if false;
    }
  }
}